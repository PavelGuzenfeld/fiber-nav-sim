# Minimal Mesa 26.0.0 DZN test — Vulkan-on-D3D12 for WSL2
# BUILD:  docker build -f docker/Dockerfile.mesa-test -t mesa-dzn-test:26.0 .
# TEST:   docker run --gpus all --rm -v /usr/lib/wsl:/usr/lib/wsl:ro mesa-dzn-test:26.0 vulkaninfo --summary

FROM nvidia/cuda:12.6.3-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    # Vulkan tools
    vulkan-tools \
    mesa-vulkan-drivers \
    libvulkan-dev \
    # Mesa DZN build deps
    meson \
    flex \
    bison \
    libelf-dev \
    libdrm-dev \
    libx11-xcb-dev \
    libxcb-dri2-0-dev \
    libxcb-dri3-dev \
    libxcb-present-dev \
    libxcb-shm0-dev \
    libxshmfence-dev \
    libxrandr-dev \
    libxxf86vm-dev \
    glslang-dev \
    glslang-tools \
    spirv-tools \
    llvm-dev \
    python3-mako \
    python3-yaml \
    python3-ply \
    python3-pip \
    pkg-config \
    # Build tools
    clang \
    lld \
    ninja-build \
    cmake \
    git \
    && rm -rf /var/lib/apt/lists/*

# Build Mesa 26.0.0 with DZN (microsoft-experimental) Vulkan driver
RUN cd /tmp \
    && git clone --depth 1 --branch mesa-26.0.0 https://gitlab.freedesktop.org/mesa/mesa.git \
    && cd mesa \
    && pip3 install --break-system-packages --force-reinstall --no-deps meson \
    && meson setup build \
       -Dvulkan-drivers=microsoft-experimental \
       -Dgallium-drivers=d3d12 \
       -Dplatforms=x11 \
       -Dglx=disabled \
       -Degl=disabled \
       -Dgbm=disabled \
       -Dprefix=/usr/local \
       -Dbuildtype=release \
    && ninja -C build -j$(nproc) \
    && ninja -C build install \
    && ldconfig \
    && rm -rf /tmp/mesa

ENV GALLIUM_DRIVER=d3d12
ENV MESA_D3D12_DEFAULT_ADAPTER_NAME=NVIDIA
ENV LD_LIBRARY_PATH=/usr/lib/wsl/lib:${LD_LIBRARY_PATH}

CMD ["vulkaninfo", "--summary"]
