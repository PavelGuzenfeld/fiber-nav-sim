# GPU + Vulkan test for O3DE headless rendering on native Ubuntu
# Validates NVIDIA Vulkan ICD is available via nvidia-container-toolkit.
#
# BUILD:
#   docker build -f docker/Dockerfile.o3de-gpu-test -t o3de-gpu-test .
#
# TEST:
#   docker run --gpus all --rm o3de-gpu-test

FROM nvidia/cuda:12.6.3-base-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=all

# Minimal deps: Xvfb + Vulkan loader + llvmpipe fallback
# NVIDIA Vulkan ICD is injected at runtime by nvidia-container-toolkit (--gpus all)
RUN apt-get update && apt-get install -y --no-install-recommends \
    xvfb \
    libxcb-xinerama0 \
    libxcb-xinput0 \
    libxkbcommon-x11-dev \
    vulkan-tools \
    mesa-vulkan-drivers \
    libvulkan-dev \
    && rm -rf /var/lib/apt/lists/*

COPY docker/gpu_test.sh /gpu_test.sh
RUN chmod +x /gpu_test.sh

CMD ["/gpu_test.sh"]
